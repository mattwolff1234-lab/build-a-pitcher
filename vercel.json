{
  "headers": [
    {
      "source": "/(.*)\\.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/(.*)\\.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=3600" }]
    },
    {
      "source": "/avatars/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }]
    }
  ],
  "redirects": [
    { "source": "/ads.txt", "destination": "https://config.playwire.com/dyn_ads/1025880/77906/ads.txt", "statusCode": 301 },
    { "source": "/", "has": [{ "type": "host", "value": "squad.goat-lab.app" }], "destination": "/goatsquad", "statusCode": 307 }
  ],
  "crons": [
    { "path": "/api/push-cron", "schedule": "0 21 * * *" }
  ],
  "rewrites": [
    { "source": "/batting", "destination": "/build-a-batter.html" },
    { "source": "/pitching", "destination": "/pitcher.html" },
    { "source": "/versus", "destination": "/versus.html" },
    { "source": "/hoops", "destination": "/build-a-baller.html" },
    { "source": "/college", "destination": "/college.html" },
    { "source": "/hockey", "destination": "/hockey.html" },
    { "source": "/monster", "destination": "/monster.html" },
    { "source": "/goatsquad", "destination": "/goatsquad.html" },
    { "source": "/squad-baseball", "destination": "/goatsquad-baseball.html" },
    { "source": "/squad-football", "destination": "/goatsquad-football.html" },
    { "source": "/nba-headshots/:img", "destination": "https://cdn.nba.com/headshots/nba/latest/260x190/:img" },
    { "source": "/mlb-headshots/:id/spots/:size", "destination": "https://midfield.mlbstatic.com/v1/people/:id/spots/:size" },
    { "source": "/nfl-headshots/:path*", "destination": "https://ratings-images-prod.pulse.ea.com/:path*" },
    { "source": "/espn-img/:path*", "destination": "https://a.espncdn.com/:path*" },
    { "source": "/wiki-img/:path*", "destination": "https://upload.wikimedia.org/:path*" },
    { "source": "/cfb", "destination": "/college.html" },
    { "source": "/striker", "destination": "/build-a-striker.html" },
    { "source": "/keeper", "destination": "/build-a-keeper.html" },
    { "source": "/versus-hoops", "destination": "/versus-hoops.html" },
    { "source": "/versus-soccer", "destination": "/versus-soccer.html" },
    { "source": "/versus-cfb", "destination": "/versus-cfb.html" },
    { "source": "/franchise", "destination": "/franchise.html" },
    { "source": "/franchise-hoops", "destination": "/franchise-hoops.html" },
    { "source": "/franchise-soccer", "destination": "/franchise-soccer.html" },
    { "source": "/p/:id", "destination": "/api/share?id=:id" },
    { "source": "/xp", "destination": "/xp-demo.html" },
    { "source": "/privacy", "destination": "/privacy.html" }
  ]
}
