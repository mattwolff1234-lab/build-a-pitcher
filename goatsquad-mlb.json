  "gauntlet": {
    "_comment": "Same shape as the NBA gauntlet: one lineup, one life, layered map with forks + traveling shops. Each team's `players` are that season's roster for the victory-spoils wheel, rated as they were THAT year (Paul O'Neill is a 78 on the '90 Reds and an 84 on the '98 Yankees). mlbamId on roster players is patched by fetch-squadball.js (era-aware people-search).",
    "title": "THE GAUNTLET",
    "subtitle": "One lineup. One life. Beat them, sign their stars, spend your winnings.",
    "logoTemplate": "https://www.mlbstatic.com/team-logos/{id}.svg",
    "economy": {
      "currency": "$",
      "gameWin": 5,
      "seriesWin": 15,
      "sweep": 10,
      "upset": 20,
      "interestPer": 5,
      "interestCap": 10,
      "homeEdge": 0.03
