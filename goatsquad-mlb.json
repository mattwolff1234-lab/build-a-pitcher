  "slug": "squadball",
  "sport": "mlb",
  "sportEmoji": "⚾",
  "tagline": "Stop the spin. Fill your lineup. Beat the boss.",
  "dataFile": "/squadball-mlb.json",
  "adapter": {
    "_comment": "primaryPositionOnly:false — a '3B/1B' player is eligible for BOTH slots (his primary is listed first). The engine adds a hard no-duplicate guard so the same name can never occupy two slots. Headshots: MLB official mugs by mlbamId; the share-card canvas swaps the prefix for the same-origin /mlb-headshots/ proxy (vercel.json rewrite).",
    "primaryPositionOnly": false,
    "poolKey": "pool",
    "legendsKey": "legends",
    "nameField": "name",
    "ratingField": "ovr",
    "posField": "pos",
    "teamField": "team",
    "imageIdField": "mlbamId",
    "posSeparator": "/",
    "imageTemplate": "https://midfield.mlbstatic.com/v1/people/{id}/spots/180",
    "canvasImageProxy": {
      "from": "https://midfield.mlbstatic.com/v1/people/",
      "to": "/mlb-headshots/"
    }
  },
