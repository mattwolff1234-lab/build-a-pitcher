  "gauntlet": {
    "_comment": "Gauntlet mode: build ONE squad, one life — beat every layer of the map. Progress, squad, Cap Space and items persist in pl_rr_gauntlet until the run dies. Each team's `players` are that season's roster for the victory-spoils WHEEL (era-specific ratings — Ray Allen is an 87 on the '08 Celtics but a 79 on the '13 Heat). logoId feeds logoTemplate for the map node crest.",
    "title": "THE GAUNTLET",
    "subtitle": "One squad. One life. Beat them, sign their stars, spend your winnings.",
    "logoTemplate": "https://cdn.nba.com/logos/nba/{id}/primary/L/logo.svg",

    "economy": {
      "_comment": "Cap Space — earned per GAME win (the counter ticks up live during the series), bonuses at the buzzer. Gone when the run dies. Interest (Balatro-style): +$1 per interestPer dollars HELD when a series is won, capped at interestCap — rewards keeping a float without making hoarding dominant. homeEdge = per-game win-prob bump in YOUR building when the Home Court Deed is owned.",
      "currency": "$",
      "gameWin": 5,
      "seriesWin": 15,
      "sweep": 10,
      "upset": 20,
      "interestPer": 5,
      "interestCap": 10,
      "homeEdge": 0.03
    },

    "shop": {
      "_comment": "The traveling shop appears at 'shop' entries in layers. `once` items can be bought once per run. Prices are Cap Space. Training Camp caps at +4 per player (2 buys).",
      "items": [
        { "id": "insurance", "icon": "🛟", "name": "Insurance Policy",  "price": 125, "once": true,  "desc": "When a loss would end your run, time rewinds to the game that killed you and the series re-flips from there. One use." },
        { "id": "camp",      "icon": "🏋️", "name": "Training Camp",     "price": 40, "once": false, "desc": "+2 OVR to one player. Max +4 per player." },
        { "id": "prime",     "icon": "⭐", "name": "Prime Boost",       "price": 55, "once": false, "desc": "One player becomes his PRIME self — his best card ever, min +4. Once per player." },
        { "id": "fa",        "icon": "🎰", "name": "Free-Agent Wheel",  "price": 50, "once": false, "desc": "Spin the whole NBA pool — your agent skews it toward stars. Somebody gets cut." },
        { "id": "relicwheel","icon": "✨", "name": "Relic Wheel",       "price": 65, "once": false, "desc": "Every card on the wheel is a relic — spoils-wheel odds, minus what you own. One STOP." },
        { "id": "token2",    "icon": "🎟️", "name": "Second-Stop Token", "price": 35, "once": true,  "desc": "Your next victory wheel: STOP twice, keep the better freeze." },
        { "id": "coach",     "icon": "📋", "name": "Coach Carousel",    "price": 25, "once": false, "desc": "Respin your coach slot. Could be Phil. Could be the Mascot." },
        { "id": "home",      "icon": "🏟️", "name": "Home Court Deed",   "price": 45, "once": true,  "desc": "Home court the rest of the run — games 1, 2, 5 and 7 in YOUR building, with an edge." },
        { "id": "rookie",    "icon": "🎓", "name": "Draft Workout",     "price": 30, "once": true,  "desc": "Spin the under-70 prospect wheel. Raw now — but he gains +1 for EVERY game you win." }
      ]
    },

    "rookieMaxRating": 69,

    "rental": {
      "_comment": "🪪 Rent-A-Ring-Chaser — Game 7 only (gauntlet): pay `price` Cap Space and a hired gun rated ≥ minRating suits up for the winner-take-all game, replacing your weakest eligible slot for that ONE game. Every eligible player — legends included — lands at EQUAL odds (no rarity bands). He leaves after the buzzer, win or lose; the money is gone either way.",
      "price": 100,
      "minRating": 90
    },

    "relicChance": 0.25,
    "maxRelics": 5,

    "_managerPerks_comment": "🎽 One-shot cards granted by the manager/coach on your squad, keyed by his OVR mod (elite 4+, good 2-3, basic 0-1, bad below 0). Each card is once per RUN. Effect types the engine understands: ovr / gameEdge / elimEdge / firstGameEdge / noMomentum / gamble.",
    "managerPerks": {
      "elite": { "label": "Hall of Fame", "band": "coach +4 or better", "items": [
        { "id": "icewater", "icon": "🧊", "name": "Ice Water", "desc": "+8% win chance in elimination games of one series.", "effect": { "type": "elimEdge", "value": 0.08 } },
        { "id": "perfectplay", "icon": "📋", "name": "The Perfect Play", "desc": "+5% win chance in every game of one series.", "effect": { "type": "gameEdge", "value": 0.05 } },
        { "id": "settone", "icon": "🔥", "name": "Set the Tone", "desc": "+18% win chance in Game 1 of one series.", "effect": { "type": "firstGameEdge", "value": 0.18 } }
      ] },
      "good": { "label": "Proven Winner", "band": "coach +2 or +3", "items": [
        { "id": "timeout", "icon": "⏱️", "name": "Timeout", "desc": "Momentum never swings against you for one series.", "effect": { "type": "noMomentum", "value": 1 } },
        { "id": "adjust", "icon": "📈", "name": "In-Game Adjustment", "desc": "+3% win chance in every game of one series.", "effect": { "type": "gameEdge", "value": 0.03 } }
      ] },
      "basic": { "label": "Journeyman", "band": "coach 0 or +1", "items": [
        { "id": "speech", "icon": "🗣️", "name": "Locker Room Speech", "desc": "+2 squad overall for one series.", "effect": { "type": "ovr", "value": 2 } }
      ] },
      "bad": { "label": "Retread", "band": "coach below 0", "items": [
        { "id": "hail", "icon": "🎲", "name": "Hail Mary", "desc": "Coin flip: +6 squad overall for one series, or −3.", "effect": { "type": "gamble", "value": 6 } }
      ] }
    },

    "_mods_comment": "🃏 Run modifiers — a fresh Gauntlet offers 3 of these (plus Standard Issue). Behavior is keyed by id in the page (modReelFilter/applyMod/etc); this file is just the wording.",
    "mods": [
      { "id": "scorched",  "icon": "🚫", "name": "No Ghosts",   "desc": "Legends never appear on your reels this run. Start with +$40." },
      { "id": "benchmob",  "icon": "💪", "name": "Bench Mob",   "desc": "Your 6th Man gets +6 after the draft. Every boss +1." },
      { "id": "headstart", "icon": "🎁", "name": "Head Start",  "desc": "Start with a random economy relic. Shop prices +30% all run." },
      { "id": "ironfive",  "icon": "🔒", "name": "Iron Five",   "desc": "No do-over: you can't drop a player and respin after the draft. +$60 up front." },
      { "id": "underdogs", "icon": "🐕", "name": "Underdogs",   "desc": "Your reels max out at 84 overall. All winnings +50%." }
    ],

    "_relics_comment": "Relics ride the victory-spoils wheel alongside players (~relicChance per card slot). Hold up to maxRelics; landing another means swapping one out. `weight` = draw odds within the relic pool (default 1) — the win-prob relics are weighted rare, the cash/economy ones common. Effect types the engine understands: gameEdge / elimEdge / firstGameEdge (win-prob bumps), noMomentumDrag, gameWinCash, interestCap, shopDiscount, upsetMult, ovrBoost.",
    "relics": [
      { "id": "ring",     "icon": "💍", "name": "The Ring",       "weight": 1, "desc": "Been there before — +6% win chance in elimination games.", "effect": { "type": "elimEdge", "value": 0.06 } },
      { "id": "rabbit",   "icon": "🍀", "name": "Rabbit's Foot",  "weight": 1, "desc": "Momentum never swings against you.",                       "effect": { "type": "noMomentumDrag", "value": 1 } },
      { "id": "microwave","icon": "🔥", "name": "The Microwave",  "weight": 1, "desc": "Instant offense — +2% win chance in every game.",          "effect": { "type": "gameEdge", "value": 0.02 } },
      { "id": "sponsor",  "icon": "💼", "name": "Sponsor Deal",   "weight": 3, "desc": "+$3 for every game you win.",                              "effect": { "type": "gameWinCash", "value": 3 } },
      { "id": "platinum", "icon": "🏦", "name": "Platinum Card",  "weight": 3, "desc": "Interest cap raised by $10.",                              "effect": { "type": "interestCap", "value": 10 } },
      { "id": "tickets",  "icon": "🎫", "name": "Season Tickets", "weight": 3, "desc": "Shop prices 25% off.",                                     "effect": { "type": "shopDiscount", "value": 0.25 } },
      { "id": "hypeman",  "icon": "📢", "name": "Hype Man",       "weight": 3, "desc": "Upset bonuses pay triple.",                                "effect": { "type": "upsetMult", "value": 3 } },
      { "id": "chemistry","icon": "🧬", "name": "Team Chemistry", "weight": 1, "desc": "Squad overall +2 in every series.",                        "effect": { "type": "ovrBoost", "value": 2 } },
      { "id": "jetlag",   "icon": "🚀", "name": "Fast Starters",  "weight": 2, "desc": "+15% win chance in Game 1.",                               "effect": { "type": "firstGameEdge", "value": 0.15 } },
      { "id": "noringers", "icon": "🚫", "name": "No Ringers", "weight": 1, "desc": "+4 squad overall — but you can never sign a spoils player again.", "effect": { "type": "noRingers", "value": 4 } },
      { "id": "proveit",   "icon": "📝", "name": "Prove-It Deal",  "weight": 1, "desc": "+3 squad overall. Game wins pay $0 — series money still counts.", "effect": { "type": "proveIt", "value": 3 } },
      { "id": "piggy",     "icon": "🐖", "name": "Piggy Bank",     "weight": 2, "desc": "+$4 every city you land in. Shatters forever the first time you buy from a shop.", "effect": { "type": "cityCash", "value": 4 } },
      { "id": "dynasty",   "icon": "🏗️", "name": "Dynasty",        "weight": 1, "desc": "+1 squad overall for every series won while holding it.", "effect": { "type": "dynasty", "value": 1 } },
      { "id": "egg",       "icon": "🥚", "name": "The Egg",        "weight": 2, "desc": "Does nothing… hatches into a random chase relic after 3 series wins.", "effect": { "type": "egg", "value": 3 } },
      { "id": "bandwagon", "icon": "🚌", "name": "Bandwagon",      "weight": 2, "desc": "Series wins pay a bonus that grows: $3, then $6, then $9…", "effect": { "type": "bandwagon", "value": 3 } },
