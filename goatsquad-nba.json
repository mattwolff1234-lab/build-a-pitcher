{
  "_comment": "GOAT Squad sport config — EVERYTHING game-specific lives here. An NFL/NHL version is a copy of this file with a new dataFile + slots + coaches + bosses, plus pointing GAME_CONFIG_URL in a clone of goatsquad.html at it. No game logic in this file.",

  "brand": "GOAT Squad",
  "slug": "goatsquad",
  "sport": "nba",
  "sportEmoji": "🏀",
  "tagline": "Stop the spin. Pick your guy. Beat the boss.",

  "dataFile": "/ballers.json",
  "adapter": {
    "_comment": "How the engine reads the sport's data file. poolKey/legendsKey are top-level arrays; fields map onto {name, rating, pos, team, imgId}. pos is split on posSeparator and trimmed ('PG / SG' -> ['PG','SG']); with primaryPositionOnly a player belongs ONLY to their first-listed position (PGs in the PG slot, SGs in the SG slot). imageTemplate: {id} is replaced with the player's imgId; players whose image fails get an initials avatar on their team color.",
    "primaryPositionOnly": true,
    "poolKey": "pool",
    "legendsKey": "legends",
    "nameField": "name",
    "ratingField": "ovr",
    "primeKey": "prime",
    "posField": "pos",
    "teamField": "team",
    "imageIdField": "nbaId",
    "posSeparator": "/",
    "imageTemplate": "https://cdn.nba.com/headshots/nba/latest/260x190/{id}.png",
    "_canvasProxy_comment": "The share-card canvas can't draw cdn.nba.com images directly (no CORS headers = tainted canvas), so it swaps this prefix for the same-origin /nba-headshots/ proxy (a vercel.json rewrite). In-game <img> tags keep the CDN.",
    "canvasImageProxy": { "from": "https://cdn.nba.com/headshots/nba/latest/260x190/", "to": "/nba-headshots/" }
  },

  "slots": [
    { "key": "pg",    "label": "PG",      "type": "player", "positions": ["PG"], "weight": 1 },
    { "key": "sg",    "label": "SG",      "type": "player", "positions": ["SG"], "weight": 1 },
    { "key": "sf",    "label": "SF",      "type": "player", "positions": ["SF"], "weight": 1 },
    { "key": "pf",    "label": "PF",      "type": "player", "positions": ["PF"], "weight": 1 },
    { "key": "c",     "label": "C",       "type": "player", "positions": ["C"],  "weight": 1 },
    { "key": "six",   "label": "6TH MAN", "type": "player", "positions": ["PG", "SG", "SF", "PF", "C"], "weight": 0.75 },
    { "key": "coach", "label": "COACH",   "type": "coach" }
  ],

  "spin": {
    "_comment": "cycleHz = faces per second (fixed rate, no rubber-banding — skilled players can learn the STOP timing). resumeMs = beat between locking a player and the remaining slots respinning. reelLength = entries per slot reel; ticks only advance while spinning, so at 10Hz a 512-entry reel is ~51s of unique faces — a normal run never sees a repeat.",
    "cycleHz": 10,
    "resumeMs": 400,
    "reelLength": 512
  },

  "rarity": {
    "_comment": "Weighted draw odds by rating band [minRating, maxRating, weight] — higher weight = more common. legendMult multiplies a legend's band weight (legends are the rarest pulls — at 0.2 one freezes on your board roughly every 12 stops, about every other gauntlet build).",
    "bands": [[0, 74, 2], [75, 79, 4.5], [80, 84, 6], [85, 89, 6], [90, 999, 4.5]],
    "legendMult": 0.2,
    "legendPity": 18
  },

